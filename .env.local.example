# Kooperatifin KENDİ Supabase projesinden alınacak (kullanıcının kişisel hesabıyla karışmamalı)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sadece sunucu tarafında (cron / Telegram webhook) kullanılır - Project Settings > API > service_role
# ASLA client'a gönderilmez, sadece admin.ts içinde kullanılır.
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron'un hatirlatma-kontrol adresini çağırırken kullandığı gizli anahtar (rastgele bir metin)
CRON_SECRET=
